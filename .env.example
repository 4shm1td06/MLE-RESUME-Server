# Server port (default: 5050)
PORT=5050

# Comma-separated allowed CORS origins (default: localhost + Vercel client)
CORS_ORIGIN=http://localhost:5173,https://mle-resume-formatter-client.vercel.app

# AI API key — at least one required for AI parsing
GROQ_API_KEY=gsk_your_key_here
# OR (fallback if GROQ_API_KEY is not set):
# OPENROUTER_API_KEY=sk-or-your-key-here

# AI API URL (default: Groq)
# AI_API_URL=https://api.groq.com/openai/v1/chat/completions

# AI model (default: mixtral-8x7b-32768)
# AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Path to Chromium for Puppeteer (required on Render/Docker, auto-detected on desktop)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Bearer token for V3 Affinda-compatible API auth. Leave empty to disable auth.
RESUME_API_KEY=
